{
  "name": "genshin-site-api",
  "version": "1.0.0",
  "description": "Backend API for Genshin Impact character, weapon, and artifact data",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "test": "jest",
    "migrate": "ts-node src/scripts/migrate.ts",
    "load:data": "ts-node src/scripts/load-data.ts",
    "load:guides": "ts-node src/scripts/load-guides.ts",
    "load:character-guides": "ts-node src/scripts/load-character-guides.ts",
    "sync": "ts-node src/scripts/run-sync.ts",
    "sync:characters": "ts-node src/scripts/run-sync.ts --type characters",
    "sync:artifacts": "ts-node src/scripts/run-sync.ts --type artifacts",
    "sync:materials": "ts-node src/scripts/run-sync.ts --type materials",
    "sync:weapons": "ts-node src/scripts/run-sync.ts --type weapons",
    "sync:icons": "ts-node src/scripts/run-sync.ts --type icons",
    "sync:all": "ts-node src/scripts/run-sync.ts --type all",
    "verify:data": "ts-node src/scripts/run-sync.ts --type verify",
    "reset:materials": "ts-node src/scripts/reset-materials.ts"
  },
  "keywords": [
    "genshin",
    "api",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "genshin-db": "^5.2.9",
    "sqlite": "^5.0.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
